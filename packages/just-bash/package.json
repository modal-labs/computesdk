{
  "name": "@computesdk/just-bash",
  "version": "0.4.10",
  "description": "just-bash provider for ComputeSDK - local sandboxed bash execution with virtual filesystem",
  "author": "ComputeSDK",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint"
  },
  "dependencies": {
    "computesdk": "workspace:*",
    "@computesdk/provider": "workspace:*",
    "nanoid": "^5.1.6"
  },
  "peerDependencies": {
    "just-bash": ">=2.0.0"
  },
  "devDependencies": {
    "just-bash": "^2.11.5",
    "@computesdk/test-utils": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.37.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "computesdk",
    "just-bash",
    "sandbox",
    "code-execution",
    "bash",
    "shell",
    "virtual-filesystem",
    "provider",
    "local"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/computesdk/computesdk.git",
    "directory": "packages/just-bash"
  },
  "homepage": "https://www.computesdk.com",
  "bugs": {
    "url": "https://github.com/computesdk/computesdk/issues"
  }
}
